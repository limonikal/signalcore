{
    "name": "signalcore",
    "version": "1.0.0",
    "description": "Typed Event-Driven core modules",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/limonikal/signalcore.git"
    },
    "homepage": "https://github.com/limonikal/signalcore",
    "bugs": {
        "url": "https://github.com/limonikal/signalcore/issues"
    },
    "keywords": [
        "typed-event-emitter",
        "event-driven",
        "typescript",
        "type-safe",
        "event-bus",
        "reactive",
        "proxy",
        "middleware",
        "event-target",
        "tree-shakeable",
        "zero-dependencies",
        "tiny"
    ],
    "license": "Apache-2.0",
    "sideEffects": false,
    "scripts": {
        "start": "vite",
        "start.host": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "preview.host": "vite preview --host",
        "previewBuild": "vite build & vite preview",
        "prepublishOnly": "vite build"
    },
    "devDependencies": {
        "typescript": "^6.0.3",
        "vite": "^8.0.11",
        "vite-plugin-dts": "^5.0.1"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "main": "./dist/index.cjs.js",
    "module": "./dist/index.esm.js",
    "types": "./dist/index.d.ts",
    "browser": "./dist/index.umd.js",
    "unpkg": "./dist/index.umd.js",
    "jsdelivr": "./dist/index.umd.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.esm.js",
            "require": "./dist/index.cjs.js"
        },
        "./package.json": "./package.json"
    }
}
